{
  "name": "bpa-owner-panel-ui",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev -p 3100",
    "dev:mother": "cross-env SITE_MODE=mother next dev -p 3100",
    "dev:shop": "cross-env SITE_MODE=shop next dev -p 3101",
    "dev:clinic": "cross-env SITE_MODE=clinic next dev -p 3102",
    "dev:admin": "cross-env SITE_MODE=admin next dev -p 3103",
    "dev:owner": "cross-env SITE_MODE=owner next dev -p 3104 --webpack",
    "dev:producer": "cross-env SITE_MODE=producer next dev -p 3105",
    "dev:country": "cross-env SITE_MODE=country next dev -p 3106",
    "dev:doctor": "cross-env SITE_MODE=doctor next dev -p 3107",
    "dev:all": "concurrently -n MOTHER,SHOP,CLINIC,ADMIN,OWNER,PRODUCER,COUNTRY,DOCTOR -c auto \"npm run dev:mother\" \"npm run dev:shop\" \"npm run dev:clinic\" \"npm run dev:admin\" \"npm run dev:owner\" \"npm run dev:producer\" \"npm run dev:country\" \"npm run dev:doctor\"",
    "build": "next build",
    "prebuild": "node scripts/deployment/guard-production-build.mjs && node scripts/clean-workspace.mjs",
    "typecheck": "tsc --noEmit -p tsconfig.json",
    "type-check": "npm run typecheck",
    "clean:workspace": "node scripts/clean-workspace.mjs",
    "validate:build": "node scripts/validate-path-aliases.mjs && node scripts/validate-jsvectormap-maps.mjs && node scripts/validate-production-build.mjs && node scripts/clean-workspace.mjs && npm run build && npm run validate:panels",
    "validate:panels": "node scripts/validate-panel-routes.mjs",
    "validate:path-aliases": "node scripts/validate-path-aliases.mjs",
    "validate:production-build": "node scripts/validate-production-build.mjs",
    "restore:vectormap": "node scripts/restore-vectormap-module.mjs",
    "validate:jsvectormap": "node scripts/validate-jsvectormap-maps.mjs",
    "start": "npm run start:staff",
    "start:staff": "next start -p 3100",
    "start:shop": "next start -p 3101",
    "start:clinic": "next start -p 3102",
    "start:admin": "next start -p 3103",
    "start:owner": "next start -p 3104",
    "start:producer": "next start -p 3105",
    "start:country": "next start -p 3106",
    "start:doctor": "next start -p 3107",
    "deploy:build": "node scripts/deployment/deploy-build.mjs",
    "deploy:pm2:phase1": "node scripts/deployment/pm2-start-phase.mjs 1",
    "deploy:pm2:phase2": "node scripts/deployment/pm2-start-phase.mjs 1-2",
    "deploy:pm2:phase3": "node scripts/deployment/pm2-start-phase.mjs 3",
    "deploy:pm2:restart:phase1": "node scripts/deployment/pm2-start-phase.mjs 1 --restart",
    "deploy:pm2:restart:phase2": "node scripts/deployment/pm2-start-phase.mjs 1-2 --restart",
    "deploy:pm2:restart:phase3": "node scripts/deployment/pm2-start-phase.mjs 3 --restart",
    "lint": "cross-env ESLINT_USE_FLAT_CONFIG=true eslint . --max-warnings 0",
    "check:landing": "node scripts/check-landing-isolation.mjs",
    "check:ui-standards": "node scripts/check-ui-standards.mjs",
    "test:e2e": "playwright test tests/e2e",
    "test:e2e:delivery": "playwright test tests/e2e/delivery-flow.spec.ts",
    "test:unit:inbound": "node --test lib/inboundTransfersUi.test.js lib/staffInventoryRoutes.test.js lib/stockRequestPoPrefill.test.js",
    "admin:generate-implemented-hrefs": "node scripts/admin/generateImplementedAdminHrefs.mjs",
    "admin:generate-implemented-hrefs:write": "node scripts/admin/generateImplementedAdminHrefs.mjs --write"
  },
  "dependencies": {
