# BPA Admin UI (multi-panel) — copy to .env and fill in
#
# API target for Next.js server proxy (app/api/v1/[[...path]]/route.js) and next.config.js fallback rewrite:
#   1) process.env.API_BASE_URL
#   2) else process.env.NEXT_PUBLIC_API_BASE_URL
#   3) else http://localhost:3000
# If the resolved URL is localhost/127.0.0.1 on ports 3100–3107 (Next panel dev ports), it is forced to
# http://localhost:3000 so /api/v1/* is never proxied to another Next instance.
#
# Browser fetch uses same-origin /api/v1/* on the panel (3100–3107); only the server-side proxy uses these vars.
# next.config.js also derives next/image remotePatterns from API_BASE_URL / NEXT_PUBLIC_API_BASE_URL (pathname /api/v1/files/**).
NEXT_PUBLIC_API_BASE_URL=http://localhost:3000
# API_BASE_URL=http://localhost:3000
NEXT_PUBLIC_AUTH_BASE_URL=http://localhost:3000
AUTH_COOKIE_NAME=bpa_admin
NEXT_PUBLIC_DEFAULT_PANEL=admin

# ─── Site identity (SEO) ─────────────────────────────────────────────────────
# Production examples per panel:
# owner  → NEXT_PUBLIC_SITE_URL=https://owner.bangladeshpetassociation.com
# shop   → NEXT_PUBLIC_SITE_URL=https://shop.bangladeshpetassociation.com
NEXT_PUBLIC_SITE_URL=http://localhost:3104
NEXT_PUBLIC_SITE_NAME=BPA Owner Panel

# ─── SEO verification (optional) ───────────────────────────────────────────
# NEXT_PUBLIC_GOOGLE_SITE_VERIFICATION=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
# NEXT_PUBLIC_FACEBOOK_DOMAIN_VERIFICATION=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
# NEXT_PUBLIC_OG_IMAGE_URL=/og-image.png
# NEXT_PUBLIC_TWITTER_SITE=bangladeshpet
# NEXT_PUBLIC_SEO_APP_SURFACE=panel

# ─── Analytics (optional — GA4 + GTM + Meta Pixel + Clarity) ─────────────────
# NEXT_PUBLIC_ANALYTICS_APP_SURFACE=panel
# NEXT_PUBLIC_GA_MEASUREMENT_ID=G-XXXXXXXXXX
# NEXT_PUBLIC_GTM_CONTAINER_ID=GTM-XXXXXXX
# NEXT_PUBLIC_META_PIXEL_ID=
# NEXT_PUBLIC_CLARITY_PROJECT_ID=

# ─── OAuth client IDs (optional — future web social login UI) ────────────────
# NEXT_PUBLIC_GOOGLE_CLIENT_ID=
# NEXT_PUBLIC_FACEBOOK_APP_ID=
